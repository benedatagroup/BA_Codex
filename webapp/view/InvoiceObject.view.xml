<mvc:View
    controllerName="bacodex.controller.InvoiceObject"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:uxap="sap.uxap">
    <uxap:ObjectPageLayout
        id="invoiceObjectPage"
        showFooter="false"
        showTitleInHeaderContent="true"
        useIconTabBar="false">
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:expandedHeading>
                    <VBox>
                        <Title text="{InvoiceNumber}" level="H1"/>
                        <Text text="{VendorName}"/>
                    </VBox>
                </uxap:expandedHeading>
                <uxap:snappedHeading>
                    <VBox>
                        <Title text="{InvoiceNumber}" level="H1"/>
                        <Text text="{VendorName}"/>
                    </VBox>
                </uxap:snappedHeading>
                <uxap:actions>
                    <Button
                        icon="sap-icon://edit"
                        text="{i18n>edit}"
                        type="Emphasized"
                        visible="{= !${editView>/editMode} }"
                        press=".onEdit"/>
                    <Button
                        icon="sap-icon://save"
                        text="{i18n>save}"
                        type="Emphasized"
                        visible="{editView>/editMode}"
                        enabled="{= !${editView>/busy} }"
                        press=".onSave"/>
                    <Button
                        icon="sap-icon://decline"
                        text="{i18n>cancel}"
                        type="Transparent"
                        visible="{editView>/editMode}"
                        enabled="{= !${editView>/busy} }"
                        press=".onCancel"/>
                    <Button
                        icon="sap-icon://nav-back"
                        text="{i18n>back}"
                        type="Transparent"
                        press=".onNavBack"/>
                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
        <uxap:headerContent>
            <FlexBox
                wrap="Wrap"
                alignItems="Start"
                class="sapUiSmallMarginTopBottom">
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Label text="{i18n>status}"/>
                    <ObjectStatus
                        text="{Status}"
                        state="{path: 'Status', formatter: '.formatter.statusState'}"/>
                </VBox>
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Label text="{i18n>netAmount}"/>
                    <ObjectNumber
                        number="{path: 'NetAmount', formatter: '.formatter.amount'}"
                        unit="{Currency}"/>
                </VBox>
                <VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <Label text="{i18n>grossAmount}"/>
                    <ObjectNumber
                        number="{path: 'GrossAmount', formatter: '.formatter.amount'}"
                        unit="{Currency}"
                        emphasized="true"/>
                </VBox>
            </FlexBox>
        </uxap:headerContent>
        <uxap:sections>
            <uxap:ObjectPageSection title="{i18n>invoiceSectionGeneral}" titleUppercase="false">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1">
                                <Label text="{i18n>invoiceId}"/>
                                <Text text="{InvoiceId}"/>
                                <Label text="{i18n>invoiceNumber}"/>
                                <Text text="{InvoiceNumber}"/>
                                <Label text="{i18n>status}"/>
                                <ObjectStatus
                                    text="{Status}"
                                    state="{path: 'Status', formatter: '.formatter.statusState'}"/>
                                <Label text="{i18n>companyCode}"/>
                                <Text text="{CompanyCode}"/>
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection title="{i18n>invoiceSectionDates}" titleUppercase="false">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1">
                                <Label text="{i18n>invoiceDate}"/>
                                <Text text="{
                                    path: 'InvoiceDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: {
                                        style: 'medium'
                                    }
                                }"/>
                                <Label text="{i18n>dueDate}"/>
                                <Text text="{
                                    path: 'DueDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: {
                                        style: 'medium'
                                    }
                                }" visible="{= !${editView>/editMode} }"/>
                                <DatePicker
                                    dateValue="{editView>/data/DueDate}"
                                    displayFormat="medium"
                                    valueFormat="yyyy-MM-dd"
                                    valueState="{editView>/valueState/DueDate}"
                                    valueStateText="{i18n>dueDateValidationError}"
                                    visible="{editView>/editMode}"/>
                                <Label text="{i18n>postingDate}"/>
                                <Text text="{
                                    path: 'PostingDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: {
                                        style: 'medium'
                                    }
                                }"/>
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection title="{i18n>invoiceSectionAmounts}" titleUppercase="false">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1">
                                <Label text="{i18n>netAmount}"/>
                                <ObjectNumber
                                    number="{path: 'NetAmount', formatter: '.formatter.amount'}"
                                    unit="{Currency}"/>
                                <Label text="{i18n>taxAmount}"/>
                                <ObjectNumber
                                    number="{path: 'TaxAmount', formatter: '.formatter.amount'}"
                                    unit="{Currency}"/>
                                <Label text="{i18n>grossAmount}"/>
                                <ObjectNumber
                                    number="{path: 'GrossAmount', formatter: '.formatter.amount'}"
                                    unit="{Currency}"
                                    emphasized="true"/>
                                <Label text="{i18n>currency}"/>
                                <Text
                                    text="{Currency}"
                                    visible="{= !${editView>/editMode} }"/>
                                <Input
                                    value="{editView>/data/Currency}"
                                    maxLength="3"
                                    valueLiveUpdate="true"
                                    valueState="{editView>/valueState/Currency}"
                                    valueStateText="{i18n>currencyValidationError}"
                                    visible="{editView>/editMode}"/>
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection title="{i18n>invoiceSectionBusinessPartner}" titleUppercase="false">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="4"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1">
                                <Label text="{i18n>vendorName}"/>
                                <Text
                                    text="{VendorName}"
                                    visible="{= !${editView>/editMode} }"/>
                                <Input
                                    value="{editView>/data/VendorName}"
                                    maxLength="120"
                                    valueLiveUpdate="true"
                                    valueState="{editView>/valueState/VendorName}"
                                    valueStateText="{i18n>vendorNameValidationError}"
                                    visible="{editView>/editMode}"/>
                                <Label text="{i18n>vendorId}"/>
                                <Text text="{VendorId}"/>
                                <Label text="{i18n>paymentTerms}"/>
                                <Text text="{PaymentTerms}"/>
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
