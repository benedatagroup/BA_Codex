<mvc:View
    controllerName="bacodex.controller.InvoiceList"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc">
    <f:DynamicPage id="invoiceListPage" fitContent="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>invoiceListTitle}" level="H1"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="sapUiSmallMarginTopBottom">
                    <OverflowToolbar design="Transparent">
                        <SearchField
                            id="searchField"
                            width="20rem"
                            placeholder="{i18n>searchPlaceholder}"
                            search=".onSearch"
                            liveChange=".onSearch"/>
                        <SegmentedButton
                            id="statusFilter"
                            selectedKey="All"
                            selectionChange=".onFilterChange">
                            <items>
                                <SegmentedButtonItem key="All" text="{i18n>statusAll}"/>
                                <SegmentedButtonItem key="Draft" text="{i18n>statusDraft}"/>
                                <SegmentedButtonItem key="Posted" text="{i18n>statusPosted}"/>
                            </items>
                        </SegmentedButton>
                        <ToolbarSpacer/>
                        <Button
                            icon="sap-icon://clear-filter"
                            text="{i18n>clearFilters}"
                            type="Transparent"
                            press=".onClearFilters"/>
                    </OverflowToolbar>
                    <OverflowToolbar design="Transparent">
                        <Label text="{i18n>invoiceDate}" labelFor="invoiceDateFilter"/>
                        <DateRangeSelection
                            id="invoiceDateFilter"
                            width="16rem"
                            displayFormat="medium"
                            change=".onFilterChange"/>
                        <Label text="{i18n>companyCode}" labelFor="companyCodeFilter"/>
                        <Select
                            id="companyCodeFilter"
                            width="9rem"
                            selectedKey="All"
                            change=".onFilterChange">
                            <items>
                                <core:Item key="All" text="{i18n>statusAll}"/>
                                <core:Item key="1000" text="1000"/>
                                <core:Item key="2000" text="2000"/>
                            </items>
                        </Select>
                        <Label text="{i18n>minGrossAmount}" labelFor="minGrossAmountFilter"/>
                        <Input
                            id="minGrossAmountFilter"
                            width="9rem"
                            type="Number"
                            change=".onFilterChange"
                            submit=".onFilterChange"/>
                    </OverflowToolbar>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table
                id="invoiceTable"
                mode="None"
                growing="true"
                growingScrollToLoad="true"
                sticky="ColumnHeaders"
                width="auto"
                items="{
                    path: '/Invoices',
                    sorter: {
                        path: 'InvoiceDate',
                        descending: true
                    }
                }">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>invoiceTableTitle}" level="H2"/>
                        <ToolbarSpacer/>
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column minScreenWidth="Tablet" demandPopin="false">
                        <Text text="{i18n>invoiceNumber}"/>
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="false">
                        <Text text="{i18n>vendorName}"/>
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>invoiceDate}"/>
                    </Column>
                    <Column hAlign="End" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>grossAmount}"/>
                    </Column>
                    <Column minScreenWidth="Phone" demandPopin="false">
                        <Text text="{i18n>status}"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onInvoicePress">
                        <cells>
                            <ObjectIdentifier title="{InvoiceNumber}" text="{InvoiceId}"/>
                            <ObjectIdentifier title="{VendorName}" text="{VendorId}"/>
                            <Text text="{
                                path: 'InvoiceDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: {
                                    style: 'medium'
                                }
                            }"/>
                            <ObjectNumber
                                number="{path: 'GrossAmount', formatter: '.formatter.amount'}"
                                unit="{Currency}"
                                emphasized="true"/>
                            <ObjectStatus
                                text="{Status}"
                                state="{path: 'Status', formatter: '.formatter.statusState'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
